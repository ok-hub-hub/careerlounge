---
import Layout from "../layouts/Layout.astro";
import { SITE } from "../config";

const heroTagline = "他の人が、実際に転職した結果を見てから決める。";

const categories = [
  { name: "ハイクラス転職", href: "/categories/highclass/", desc: "ビズリーチ・JAC・リクルートダイレクトスカウト", emoji: "👔" },
  { name: "IT エンジニア", href: "/categories/it-engineer/", desc: "レバテック・Forkwell・Geekly・type IT 系", emoji: "💻" },
  { name: "営業職", href: "/categories/sales/", desc: "営業特化エージェント・ハイクラス営業向け", emoji: "📈" },
  { name: "コンサル・金融", href: "/categories/consulting-finance/", desc: "アクシスコンサルティング・コトラ系", emoji: "📊" },
  { name: "第二新卒・20代", href: "/categories/young/", desc: "マイナビジョブ20's・UZUZ・キャリアスタート", emoji: "🌱" },
  { name: "外資・グローバル", href: "/categories/global/", desc: "ロバート・ウォルターズ・JAC・ヘイズ", emoji: "🌏" },
];

const compareFeatures = [
  {
    title: "実体験ベースの口コミ",
    body: "提供品・タイアップではなく、実際に登録・利用した転職者の体験をモデレーションして公開します。",
  },
  {
    title: "年代・業界・職種で絞れる",
    body: "20 代後半 IT エンジニア、30 代営業職、第二新卒コンサルなど、自分に近い条件の口コミだけ抽出可能を設計中。",
  },
  {
    title: "年収口コミは時期と業界をセットで",
    body: "「○○年に転職して年収 X 万 → Y 万」を、時期・業界・職種・地域とセットで表示。誇張・偏向を抑制します。",
  },
];
---

<Layout>
  <section class="rounded-2xl bg-gradient-to-br from-sky-100 via-blue-50 to-white p-8 shadow-sm sm:p-12">
    <p class="text-xs font-bold tracking-widest text-[var(--color-brand-600)] uppercase">Phase 1 構築中 · 2026 開設</p>
    <h1 class="mt-3 text-3xl leading-tight font-bold text-stone-900 sm:text-4xl">
      {heroTagline}
    </h1>
    <p class="mt-4 max-w-2xl text-base leading-7 text-stone-700 sm:text-lg">
      {SITE.name} は、転職エージェント・転職体験談・年収口コミを、実体験ベースで集める UGC プラットフォームです。
      ハイクラス・IT・営業・コンサル・第二新卒・外資など、職種と年代を横断して使える「同じ立場の人の決断」を可視化します。
    </p>
    <div class="mt-6 flex flex-wrap gap-3">
      <a
        href="/submit/"
        class="inline-flex items-center rounded-lg bg-[var(--color-brand-600)] px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-[var(--color-brand-700)]"
      >
        体験談を投稿する（準備中）
      </a>
      <a
        href="/compare/"
        class="inline-flex items-center rounded-lg border border-stone-300 bg-white px-5 py-2.5 text-sm font-semibold text-stone-700 transition hover:border-[var(--color-brand-600)] hover:text-[var(--color-brand-600)]"
      >
        エージェント比較を見る（準備中）
      </a>
    </div>
  </section>

  <section class="mt-14">
    <h2 class="text-xl font-bold tracking-tight text-stone-900 sm:text-2xl">カテゴリ</h2>
    <p class="mt-1 text-sm text-stone-600">Phase 1 ではカテゴリ構造の枠だけを公開しています。記事・口コミは順次追加予定です。</p>
    <ul class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        categories.map(cat => (
          <li>
            <a
              href={cat.href}
              class="block h-full rounded-xl border border-stone-200 bg-white p-5 transition hover:border-[var(--color-brand-500)] hover:shadow-sm"
            >
              <div class="flex items-center gap-2">
                <span class="text-2xl" aria-hidden="true">{cat.emoji}</span>
                <span class="text-base font-semibold text-stone-900">{cat.name}</span>
              </div>
              <p class="mt-2 text-sm leading-6 text-stone-600">{cat.desc}</p>
              <p class="mt-3 text-xs text-stone-400">準備中</p>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="mt-14 rounded-xl border border-stone-200 bg-white p-6 sm:p-8">
    <h2 class="text-xl font-bold tracking-tight text-stone-900 sm:text-2xl">{SITE.name} の設計</h2>
    <ul class="mt-6 grid gap-6 sm:grid-cols-3">
      {
        compareFeatures.map(p => (
          <li>
            <p class="text-sm font-bold text-[var(--color-brand-600)]">{p.title}</p>
            <p class="mt-2 text-sm leading-6 text-stone-700">{p.body}</p>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="mt-14 rounded-xl border border-amber-300 bg-amber-50 p-5 text-sm leading-7 text-amber-900">
    <p class="font-semibold">Phase 1 のお知らせ</p>
    <p class="mt-1">
      現在サイトは基盤構築フェーズです。投稿フォーム・エージェント一覧・比較記事・口コミ一覧は順次公開します。
      準備状況は <a href="/about/" class="underline">運営者情報</a> をご覧ください。
    </p>
  </section>
</Layout>
