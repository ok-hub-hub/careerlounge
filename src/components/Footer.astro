---
import { SITE } from "../config";
const year = new Date().getFullYear();
---

<footer class="mt-20 border-t border-stone-200 bg-white">
  <div class="mx-auto w-full max-w-5xl px-4 py-10 sm:px-6 lg:px-8">
    <div class="grid gap-8 md:grid-cols-3">
      <div>
        <p class="text-base font-bold text-[var(--color-brand-600)]">{SITE.name}</p>
        <p class="mt-2 max-w-md text-sm leading-6 text-stone-600">
          {SITE.description}
        </p>
      </div>
      <nav aria-label="サイト情報">
        <p class="text-xs font-semibold tracking-wider text-stone-500 uppercase">サイト情報</p>
        <ul class="mt-3 space-y-1.5 text-sm">
          <li><a href="/about/" class="text-stone-700 hover:text-[var(--color-brand-600)]">運営者情報</a></li>
          <li><a href="/contact/" class="text-stone-700 hover:text-[var(--color-brand-600)]">お問い合わせ</a></li>
          <li><a href="/submit/" class="text-stone-700 hover:text-[var(--color-brand-600)]">投稿ガイドライン</a></li>
        </ul>
      </nav>
      <nav aria-label="法令・規約">
        <p class="text-xs font-semibold tracking-wider text-stone-500 uppercase">法令・規約</p>
        <ul class="mt-3 space-y-1.5 text-sm">
          <li><a href="/privacy/" class="text-stone-700 hover:text-[var(--color-brand-600)]">プライバシーポリシー</a></li>
          <li><a href="/terms/" class="text-stone-700 hover:text-[var(--color-brand-600)]">利用規約</a></li>
          <li><a href="/pr-disclosure/" class="text-stone-700 hover:text-[var(--color-brand-600)]">広告・PR表示</a></li>
          <li><a href="/disclaimer/" class="text-stone-700 hover:text-[var(--color-brand-600)]">免責事項</a></li>
        </ul>
      </nav>
    </div>
    <p class="mt-10 border-t border-stone-200 pt-6 text-xs text-stone-500">
      © {year} {SITE.name}（{SITE.author}）. 本サイトはアフィリエイトリンクを含みます。
    </p>
  </div>
</footer>
